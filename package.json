{
  "name": "yuki-pi",
  "version": "0.1.0",
  "description": "Personal Pi package for custom extensions and tweaks.",
  "type": "module",
  "keywords": [
    "pi-package"
  ],
  "scripts": {
    "test": "node --test test/*.test.ts",
    "typecheck": "tsc --noEmit"
  },
  "pi": {
    "extensions": [
      "./extensions/*.ts",
      "./extensions/todo/index.ts",
      "./extensions/plan-flow/index.ts",
      "./pi-subagent/index.ts",
      "./node_modules/pi-web-access/index.ts"
    ],
    "skills": [
      "./node_modules/pi-web-access/skills"
    ]
  },
  "dependencies": {
    "pi-web-access": "^0.10.7"
  },
  "bundledDependencies": [
    "pi-web-access"
  ],
  "peerDependencies": {
    "@earendil-works/pi-ai": "*",
    "@earendil-works/pi-agent-core": "*",
    "@earendil-works/pi-coding-agent": "*",
    "@earendil-works/pi-tui": "*",
    "typebox": "*"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "typescript": "^5.7.0"
  }
}
